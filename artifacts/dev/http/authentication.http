### ===================================================
### Auth - Register
### ===================================================

### POST /api/v1/auth/register - Registrar novo usuário
POST {{host}}/api/v1/auth/register
Content-Type: {{contentType}}

{
  "name": "Usuário Teste",
  "email": "teste@example.com",
  "password": "senha12345"
}

> {%
    client.test("Status 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    client.test("Retorna accessToken", function() {
        client.assert(response.body.accessToken != null, "accessToken ausente");
        client.assert(response.body.expiresIn === 900, "expiresIn esperado 900");
    });
    if (response.status === 201) {
        client.global.set("accessToken", response.body.accessToken);
    }
%}

### POST /api/v1/auth/register - Email já cadastrado (espera 409)
POST {{host}}/api/v1/auth/register
Content-Type: {{contentType}}

{
  "name": "Usuário Duplicado",
  "email": "teste@example.com",
  "password": "senha12345"
}

> {%
    client.test("Status 409 - Email já existe", function() {
        client.assert(response.status === 409, "Expected 409, got " + response.status);
    });
    client.test("Retorna erro com chave correta", function() {
        var hasKey = response.body.items.some(function(item) {
            return item.key === "auth.error.email-already-exists";
        });
        client.assert(hasKey, "Chave auth.error.email-already-exists ausente");
    });
%}

### POST /api/v1/auth/register - Validação de campos (espera 400)
POST {{host}}/api/v1/auth/register
Content-Type: {{contentType}}

{
  "name": "",
  "email": "email-invalido",
  "password": "123"
}

> {%
    client.test("Status 400 - Validação", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
    client.test("Retorna itens de erro", function() {
        client.assert(response.body.items.length > 0, "Nenhum item de erro retornado");
    });
%}

### ===================================================
### Auth - Login (email/senha)
### ===================================================

### POST /api/v1/auth/login - Login com credenciais válidas
POST {{host}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "email": "teste@example.com",
  "password": "senha12345"
}

> {%
    client.test("Status 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Retorna accessToken", function() {
        client.assert(response.body.accessToken != null, "accessToken ausente");
        client.assert(response.body.expiresIn === 900, "expiresIn esperado 900");
    });
    if (response.status === 200) {
        client.global.set("accessToken", response.body.accessToken);
    }
%}

### POST /api/v1/auth/login - Credenciais inválidas (espera 401)
POST {{host}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "email": "teste@example.com",
  "password": "senhaErrada"
}

> {%
    client.test("Status 401 - Credenciais inválidas", function() {
        client.assert(response.status === 401, "Expected 401, got " + response.status);
    });
%}

