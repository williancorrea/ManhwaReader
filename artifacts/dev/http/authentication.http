### ===================================================
### Auth - Google Login
### ===================================================

### POST /api/v1/auth/google - Login com Google (substituir idToken por token real)
POST {{host}}/api/v1/auth/google
Content-Type: {{contentType}}

{
  "idToken": "SUBSTITUIR_PELO_ID_TOKEN_DO_GOOGLE"
}

> {%
    client.test("Status 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Retorna accessToken e isNewUser", function() {
        client.assert(response.body.accessToken != null, "accessToken ausente");
        client.assert(response.body.isNewUser != null, "isNewUser ausente");
    });
    if (response.status === 200) {
        client.global.set("accessToken", response.body.accessToken);
    }
%}

### POST /api/v1/auth/google - Token inválido (espera 400)
POST {{host}}/api/v1/auth/google
Content-Type: {{contentType}}

{
  "idToken": "token.invalido.aqui"
}

> {%
    client.test("Status 400 - Token inválido", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
%}

### ===================================================
### Auth - Refresh Token
### ===================================================

### POST /api/v1/auth/refresh - Renovar access token (refresh token vem do cookie)
POST {{host}}/api/v1/auth/refresh

> {%
    client.test("Status 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Retorna novo accessToken", function() {
        client.assert(response.body.accessToken != null, "accessToken ausente");
        client.assert(response.body.expiresIn === 900, "expiresIn esperado 900");
    });
    if (response.status === 200) {
        client.global.set("accessToken", response.body.accessToken);
    }
%}

### POST /api/v1/auth/refresh - Sem cookie (espera 400)
# Executar em sessão limpa (sem cookies) para testar erro
POST {{host}}/api/v1/auth/refresh

> {%
    client.test("Status 400 - Refresh token ausente", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
%}

